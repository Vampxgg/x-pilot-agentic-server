data: {"task_id":"a99bb0bd-7702-4824-ad4f-902cf994eabc","conversation_id":"9b96eb19-fa04-43a3-8c44-07923f4badfb","message_id":"task_ba7a4698","created_at":1778648233.574,"event":"agent_log","data":{"id":"6d1b63c2-04ed-4f6e-ae4d-5359ee873409","node_id":"1778648109291","node_execution_id":"exec_33fcd05d","parent_id":"4e786516-99e6-4530-a7e1-f545657eb267","label":"CALL workspace_write","step":"act","status":"started","node_type":"tool","data":{"tool_name":"workspace_write","tool_call_id":"tool_workspace_write_8nXsXp5vsadZKMyzD46F","tool_input":{"content":"import React from \"react\";\nimport { useNavigate } from \"react-router-dom\";\nimport { ResizableHandle, ResizablePanel, ResizablePanelGroup } from \"@/components/ui/resizable\";\nimport { Box, Bone, Film, Settings2, Gamepad2 } from \"lucide-react\";\nimport { cn } from \"@/lib/utils\";\nimport ShortcutPanel, { Shortcut } from \"./ShortcutPanel\";\n\ninterface BlenderWorkspaceLayoutProps {\n  children: React.ReactNode;\n  shortcuts: Shortcut[];\n  activeStep: number;\n}\n\nconst STEPS = [\n  { id: 1, path: \"/\", title: \"场景与建模\", icon: Box },\n  { id: 2, path: \"/rigging\", title: \"骨骼绑定\", icon: Bone },\n  { id: 3, path: \"/animation\", title: \"关键帧动画\", icon: Film },\n  { id: 4, path: \"/practice\", title: \"实战演练\", icon: Gamepad2 },\n];\n\nexport default function BlenderWorkspaceLayout({ children, shortcuts, activeStep }: BlenderWorkspaceLayoutProps) {\n  const navigate = useNavigate();\n\n  return (\n    <div className=\"h-screen w-screen bg-zinc-950 text-zinc-300 font-sans overflow-hidden flex flex-col\">\n      {/* Top Menu Bar */}\n      <div className=\"h-8 bg-zinc-900 border-b border-zinc-800 flex items-center px-4 gap-6 text-xs text-zinc-400\">\n        <div className=\"flex items-center gap-2\">\n          <div className=\"w-4 h-4 bg-[#E28743] rounded-sm flex items-center justify-center text-zinc-950 font-bold\">\n            B\n          </div>\n          <span className=\"font-semibold text-zinc-200\">Blender Tutorial</span>\n        </div>\n        <div className=\"flex gap-4\">\n          <span className=\"hover:text-zinc-200 cursor-pointer\">File</span>\n          <span className=\"hover:text-zinc-200 cursor-pointer\">Edit</span>\n          <span className=\"hover:text-zinc-200 cursor-pointer\">Render</span>\n          <span className=\"hover:text-zinc-200 cursor-pointer\">Window</span>\n          <span className=\"hover:text-zinc-200 cursor-pointer\">Help</span>\n        </div>\n      </div>\n\n      {/* Main Workspace */}\n      <div className=\"flex-1 overflow-hidden\">\n        <ResizablePanelGroup direction=\"horizontal\">\n          {/* Left Navigation Panel */}\n          <ResizablePanel defaultSize={15} minSize={10} maxSize={20}>\n            <div className=\"h-full bg-zinc-900 border-r border-zinc-800 flex flex-col\">\n              <div className=\"flex items-center gap-2 px-3 py-2 bg-zinc-950 border-b border-zinc-800 text-xs font-semibold uppercase tracking-wider text-zinc-400\">\n                <Settings2 className=\"w-4 h-4\" />\n                工作流 (Workflow)\n              </div>\n              <div className=\"flex-1 p-2 space-y-1\">\n                {STEPS.map((step) => {\n                  const Icon = step.icon;\n                  const isActive = step.id === activeStep;\n                  return (\n                    <button\n                      key={step.id}\n                      onClick={() => navigate(step.path)}\n                      className={cn(\n                        \"w-full flex items-center gap-2 px-3 py-2 rounded-sm text-sm text-left transition-colors\",\n                        isActive\n                          ? \"bg-[#E28743]/20 text-[#E28743]\"\n                          : \"text-zinc-400 hover:bg-zinc-800 hover:text-zinc-200\"\n                      )}\n                    >\n                      <Icon className=\"w-4 h-4\" />\n                      <span>{step.id}. {step.title}</span>\n                    </button>\n                  );\n                })}\n              </div>\n            </div>\n          </ResizablePanel>\n\n          <ResizableHandle className=\"w-1 bg-zinc-800 hover:bg-[#E28743]/50 transition-colors\" />\n\n          {/* Center Main View */}\n          <ResizablePanel defaultSize={65}>\n            <div className=\"h-full bg-zinc-950 relative overflow-hidden\">\n              {children}\n            </div>\n          </ResizablePanel>\n\n          <ResizableHandle className=\"w-1 bg-zinc-800 hover:bg-[#E28743]/50 transition-colors\" />\n\n          {/* Right Shortcut Panel */}\n          <ResizablePanel defaultSize={20} minSize={15} maxSize={30}>\n            <ShortcutPanel shortcuts={shortcuts} />\n          </ResizablePanel>\n        </ResizablePanelGroup>\n      </div>\n\n      {/* Bottom Status Bar */}\n      <div className=\"h-6 bg-zinc-900 border-t border-zinc-800 flex items-center px-4 text-[10px] text-zinc-500 justify-between\">\n        <div className=\"flex gap-4\">\n          <span>左键: 选择</span>\n          <span>中键: 旋转视图</span>\n          <span>Shift+中键: 平移视图</span>\n        </div>\n        <div>\n          Blender 3D 动画实战：火柴人推箱子\n        </div>\n      </div>\n    </div>\n  );\n}\n","name":"assets/components/BlenderWorkspaceLayout.tsx"}},"error":null}}

