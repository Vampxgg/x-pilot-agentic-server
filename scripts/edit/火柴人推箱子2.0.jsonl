0 font-bold\\\">\\n            B\\n          </div>\\n          <span className=\\\"font-semibold text-zinc-200\\\">Blender Tutorial</span>\\n        </div>\\n        <div className=\\\"flex gap-4\\\">\\n          <span className=\\\"hover:text-zinc-200 cursor-pointer\\\">File</span>\\n          <span className=\\\"hover:text-zinc-200 cursor-pointer\\\">Edit</span>\\n          <span className=\\\"hover:text-zinc-200 cursor-pointer\\\">Render</span>\\n          <span className=\\\"hover:text-zinc-200 cursor-pointer\\\">Window</span>\\n          <span className=\\\"hover:text-zinc-200 cursor-pointer\\\">Help</span>\\n        </div>\\n      </div>\\n\\n      {/* Main Workspace */}\\n      <div className=\\\"flex-1 overflow-hidden\\\">\\n        <ResizablePanelGroup direction=\\\"horizontal\\\">\\n          {/* Left Navigation Panel */}\\n          <ResizablePanel defaultSize={15} minSize={10} maxSize={20}>\\n            <div className=\\\"h-full bg-zinc-900 border-r border-zinc-800 flex flex-col\\\">\\n              <div className=\\\"flex items-center gap-2 px-3 py-2 bg-zinc-950 border-b border-zinc-800 text-xs font-semibold uppercase tracking-wider text-zinc-400\\\">\\n                <Settings2 className=\\\"w-4 h-4\\\" />\\n                工作流 (Workflow)\\n              </div>\\n              <div className=\\\"flex-1 p-2 space-y-1\\\">\\n                {STEPS.map((step) => {\\n                  const Icon = step.icon;\\n                  const isActive = step.id === activeStep;\\n                  return (\\n                    <button\\n                      key={step.id}\\n                      onClick={() => navigate(step.path)}\\n                      className={cn(\\n                        \\\"w-full flex items-center gap-2 px-3 py-2 rounded-sm text-sm text-left transition-colors\\\",\\n                        isActive\\n                          ? \\\"bg-[#E28743]/20 text-[#E28743]\\\"\\n                          : \\\"text-zinc-400 hover:bg-zinc-800 hover