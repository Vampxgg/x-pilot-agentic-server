data: {"task_id":"353f8042-bfd3-4efa-9cc3-e3325b4e906e","conversation_id":"8de0d9c4-c170-484d-aec0-f7fc0d8308ab","message_id":"task_1b74bd1d","created_at":1778561992.945,"event":"agent_log","data":{"id":"776bd4e6-0b0a-4bba-8f12-b50ddf3d8ec9","node_id":"1778561824054","node_execution_id":"1778561824054","parent_id":"3a0a2f43-da24-49a2-9fe7-72bc6bffa226","label":"CALL workspace_write","step":"act","status":"started","node_type":"tool","data":{"tool_name":"workspace_write","tool_call_id":"da85ce027c294c208ac82e904b7916dc","tool_input":{"content":"import React from 'react';\nimport { Quad, INITIAL_QUAD } from '@/components/PerspectiveLabPage';\nimport { Card, CardHeader, CardTitle, CardContent } from \"@/components/ui/card\";\nimport { Button } from \"@/components/ui/button\";\nimport { ScanFace, Square, Move3d, FlipHorizontal } from \"lucide-react\";\n\ninterface ScenarioPresetsProps {\n  setPoints: React.Dispatch<React.SetStateAction<Quad>>;\n}\n\nconst PRESETS = [\n  {\n    name: '标准矩形 (Reset)',\n    desc: '恢复默认无形变状态',\n    icon: Square,\n    points: INITIAL_QUAD\n  },\n  {\n    name: '倾斜文档 (Tilted Scan)',\n    desc: '模拟手机侧面拍摄文档',\n    icon: ScanFace,\n    points: [\n      { x: 160, y: 140 },\n      { x: 440, y: 80 },\n      { x: 490, y: 380 },\n      { x: 90, y: 420 },\n    ] as Quad\n  },\n  {\n    name: '地面视角 (Ground View)',\n    desc: '模拟3D游戏中的地面透视',\n    icon: Move3d,\n    points: [\n      { x: 200, y: 250 },\n      { x: 400, y: 250 },\n      { x: 550, y: 400 },\n      { x: 50, y: 400 },\n    ] as Quad\n  },\n  {\n    name: '仿射错切 (Affine Shear)',\n    desc: '保持平行线的2D仿射变换',\n    icon: FlipHorizontal,\n    points: [\n      { x: 200, y: 100 },\n      { x: 600, y: 100 },\n      { x: 500, y: 400 },\n      { x: 100, y: 400 },\n    ] as Quad\n  }\n];\n\nexport default function ScenarioPresets({ setPoints }: ScenarioPresetsProps) {\n  return (\n    <Card className=\"bg-zinc-900/60 border-zinc-800 shadow-lg\">\n      <CardHeader className=\"pb-3 border-b border-zinc-800/50\">\n        <CardTitle className=\"text-sm font-medium text-zinc-100 flex items-center gap-2\">\n          <ScanFace className=\"w-4 h-4 text-cyan-400\" />\n          典型应用场景 (Scenarios)\n        </CardTitle>\n      </CardHeader>\n      <CardContent className=\"pt-4\">\n        <div className=\"grid grid-cols-1 gap-2\">\n          {PRESETS.map((preset, i) => {\n            const Icon = preset.icon;\n            return (\n              <Button\n                key={i}\n                variant=\"outline\"\n                className=\"w-full justify-start h-auto py-3 px-4 bg-zinc-950/50 border-zinc-800 hover:bg-cyan-950/30 hover:border-cyan-800 hover:text-cyan-400 transition-all text-left\"\n                onClick={() => setPoints(preset.points)}\n              >\n                <Icon className=\"w-4 h-4 mr-3 shrink-0\" />\n                <div className=\"flex flex-col items-start\">\n                  <span className=\"text-xs font-medium\">{preset.name}</span>\n                  <span className=\"text-[10px] text-zinc-500\">{preset.desc}</span>\n                </div>\n              </Button>\n            );\n          })}\n        </div>\n      </CardContent>\n    </Card>\n  );\n}\n","name":"assets/components/ScenarioPresets.tsx"}},"error":null}}

