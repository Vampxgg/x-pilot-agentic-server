om\\\\\\\";\\\\nimport PerspectiveLabPage from \\\\\\\"@/pages/PerspectiveLabPage\\\\\\\";\\\\n\\\\nconst appRoutes: RouteObject[] = [\\\\n  {\\\\n    path: \\\\\\\"/\\\\\\\",\\\\n    element: <PerspectiveLabPage />,\\\\n  },\\\\n];\\\\n\\\\nexport default appRoutes;\\\\n\\\",\\n          \\\"name\\\": \\\"assets/App.tsx\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/App.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 2,\\n        \\\"success\\\": true\\n      },\\n      {\\n        \\\"toolName\\\": \\\"workspace_write\\\",\\n        \\\"input\\\": {\\n          \\\"name\\\": \\\"assets/pages/PerspectiveLabPage.tsx\\\",\\n          \\\"content\\\": \\\"import React, { useState, useMemo } from 'react';\\\\nimport { ResizablePanelGroup, ResizablePanel, ResizableHandle } from \\\\\\\"@/components/ui/resizable\\\\\\\";\\\\nimport TransformCanvas from \\\\\\\"@/components/TransformCanvas\\\\\\\";\\\\nimport MatrixDisplay from \\\\\\\"@/components/MatrixDisplay\\\\\\\";\\\\nimport CoordinateController from \\\\\\\"@/components/CoordinateController\\\\\\\";\\\\nimport ScenarioPresets from \\\\\\\"@/components/ScenarioPresets\\\\\\\";\\\\nimport TheoryAccordion from \\\\\\\"@/components/TheoryAccordion\\\\\\\";\\\\n\\\\nexport type Point = { x: number; y: number };\\\\nexport type Quad = [Point, Point, Point, Point];\\\\n\\\\nexport const IMAGE_W = 400;\\\\nexport const IMAGE_H = 300;\\\\n\\\\nexport const INITIAL_QUAD: Quad = [\\\\n  { x: 100, y: 100 },\\\\n  { x: 500, y: 100 },\\\\n  { x: 500, y: 400 },\\\\n  { x: 100, y: 400 },\\\\n];\\\\n\\\\nexport function computeMatrix(w: number, h: number, pts: Quad): number[] | null {\\\\n  const x0 = pts[0].x, y0 = pts[0].y;\\\\n  const x1 = pts[1].x, y1 = pts[1].y;\\\\n  const x2 = pts[2].x, y2 = pts[2].y;\\\\n  const x3 = pts[3].x, y3 = pts[3].y;\\\\n\\\\n  const dx1 = x1 - x2;\\\\n  const dx2 = x3 - x2;\\\\n  const dx3 = x0 - x1 + x2 - x3;\\\\n\\\\n  const dy1 = y1 - y2;\\\\n  const dy2 = y3 - y2;\\\\n  const dy3 = y0 - y1 + y2 - y3;\\\\n\\\\n  let a, b, c, d, e, f, g, h_val;\\\\n\\\\n  if (dx3 === 0 && dy3 === 0) {\\\\n    // Affine\\\\n    a = x1 - x0; b = x3 - x0; c = x0;\\\\n    d = y1 - y0; e = y3 - y0; f = y0;\\\\n    g = 0; h_val = 0;\\\\n  } else {\\\\n    // Perspective\\\\n    const det = dx1 * dy2 - dx2 * dy1;\\\\n    if (det === 0) return null;\\\\n    g = (dx3 * dy2 - dx2 * dy3) / det;\\\\n    h_val = (dx1 * dy3 - dx3 * dy1) / det;\\\\n    a = x1 - x0 + g * x1;\\\\n    b = x3 - x0 + h_val * x3;\\\\n    c = x0;\\\\n    d = y1 - y0 + g * y1;\\\\n    e = y3 - y0 + h_val * y3;\\\\n    f = y0;\\\\n  }\\\\n\\\\n  return [\\\\n    a/w, d/w, 0, g/w,\\\\n    b/h, e/h, 0, h_val/h,\\\\n    0,   0,   1, 0,\\\\n    c,   f,   0, 1\\\\n  ];\\\\n}\\\\n\\\\nexport default function PerspectiveLabPage() {\\\\n  const [points, setPoints] = useState<Quad>(INITIAL_QUAD);\\\\n  \\\\n  const matrix = useMemo(() => computeMatrix(IMAGE_W, IMAGE_H, points), [points]);\\\\n\\\\n  return (\\\\n    <div className=\\\\\\\"h-screen w-full bg-zinc-950 text-zinc-50 flex flex-col font-sans overflow-hidden\\\\\\\">\\\\n      {/* Header */}\\\\n      <header className=\\\\\\\"px-6 py-4 border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md flex items-center justify-between z-20 shrink-0\\\\\\\">\\\\n         <div className=\\\\\\\"flex items-center gap-3\\\\\\\">\\\\n           <div className=\\\\\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-500 to-emerald-500 flex items-center justify-center shadow-[0_0_15px_rgba(6,182,212,0.5)]\\\\\\\">\\\\n             <svg width=\\\\\\\"18\\\\\\\" height=\\\\\\\"18\\\\\\\" viewBox=\\\\\\\"0 0 24 24\\\\\\\" fill=\\\\\\\"none\\\\\\\" stroke=\\\\\\\"currentColor\\\\\\\" strokeWidth=\\\\\\\"2\\\\\\\" strokeLinecap=\\\\\\\"round\\\\\\\" strokeLinejoin=\\\\\\\"round\\\\\\\" className=\\\\\\\"text-zinc-950\\\\\\\"><path d=\\\\\\\"M3 3h18v18H3z\\\\\\\"/><path d=\\\\\\\"m3 3 18 18\\\\\\\"/><path d=\\\\\\\"m21 3-18 18\\\\\\\"/></svg>\\\\n           </div>\\\\n           <h1 className=\\\\\\\"text-xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-emerald-400\\\\\\\">\\\\n             透视变换交互实验台\\\\n           </h1>\\\\n         </div>\\\\n         <div className=\\\\\\\"text-sm text-zinc-400 font-mono tracking-wider\\\\\\\">Perspective Transform Lab</div>\\\\n      </header>\\\\n\\\\n      {/* Main Content */}\\\\n      <main className=\\\\\\\"flex-1 overflow-hidden relative\\\\\\\">\\\\n        <ResizablePanelGroup direction=\\\\\\\"horizontal\\\\\\\" className=\\\\\\\"h-full w-full\\\\\\\">\\\\n          {/* Left: Canvas */}\\\\n          <ResizablePanel defaultSize={65} minSize={40} className=\\\\\\\"relative bg-zinc-950 flex items-center justify-center overflow-hidden\\\\\\\">\\\\n            {/* Grid Background */}\\\\n            <div className=\\\\\\\"absolute inset-0 pointer-events-none bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:40px_40px]\\\\\\\"></div>\\\\n            <div className=\\\\\\\"absolute inset-0 pointer-events-none bg-[radial-gradient(circle_800px_at_50%_50%,rgba(6,182,212,0.05),transparent)]\\\\\\\"></div>\\\\n            \\\\n            <TransformCanvas points={points} setPoints={setPoints} matrix={matrix} />\\\\n          </ResizablePanel>\\\\n          \\\\n          <ResizableHandle className=\\\\\\\"bg-zinc-800 w-1 hover:bg-cyan-500/50 transition-colors\\\\\\\" />\\\\n          \\\\n          {/* Right: Controls & Data */}\\\\n          <ResizablePanel defaultSize={35} minSize={25} className=\\\\\\\"bg-zinc-900/90 border-l border-zinc-800 flex flex-col z-10 relative shadow-2xl\\\\\\\">\\\\n            <div className=\\\\\\\"flex-1 overflow-y-auto p-6 space-y-8 custom-scrollbar\\\\\\\">\\\\n              <MatrixDisplay matrix={matrix} />\\\\n              <CoordinateController points={points} setPoints={setPoints} />\\\\n              <ScenarioPresets setPoints={setPoints} />\\\\n              <TheoryAccordion />\\\\n            </div>\\\\n          </ResizablePanel>\\\\n        </ResizablePanelGroup>\\\\n      </main>\\\\n    </div>\\\\n  );\\\\n}\\\\n\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/pages/PerspectiveLabPage.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 1,\\n        \\\"success\\\": true\\n      },\\n      {\\n        \\\"toolName\\\": \\\"workspace_write\\\",\\n        \\\"input\\\": {\\n          \\\"name\\\": \\\"assets/components/TransformCanvas.tsx\\\",\\n          \\\"content\\\": \\\"import React, { useState, useEffect, useRef } from 'react';\\\\nimport { Quad } from '@/pages/PerspectiveLabPage';\\\\nimport { cn } from '@/lib/utils';\\\\nimport { IMAGE_W, IMAGE_H } from '@/pages/PerspectiveLabPage';\\\\n\\\\ninterface TransformCanvasProps {\\\\n  points: Quad;\\\\n  setPoints: React.Dispatch<React.SetStateAction<Quad>>;\\\\n  matrix: number[] | null;\\\\n}\\\\n\\\\nexport default function TransformCanvas({ points, setPoints, matrix }: TransformCanvasProps) {\\\\n  const [draggingIdx, setDraggingIdx] = useState<number | null>(null);\\\\n  const containerRef = useRef<HTMLDivElement>(null);\\\\n\\\\n  useEffect(() => {\\\\n    const handlePointerMove = (e: PointerEvent) => {\\\\n      if (draggingIdx === null) return;\\\\n      \\\\n      setPoints(prev => {\\\\n        const next = [...prev] as Quad;\\\\n        next[draggingIdx] = {\\\\n          x: next[draggingIdx].x + e.movementX,\\\\n          y: next[draggingIdx].y + e.movementY\\\\n        };\\\\n        return next;\\\\n      });\\\\n    };\\\\n\\\\n    const handlePointerUp = () => {\\\\n      setDraggingIdx(null);\\\\n    };\\\\n\\\\n    if (draggingIdx !== null) {\\\\n      window.addEventListener('pointermove', handlePointerMove);\\\\n      window.addEventListener('pointerup', handlePointerUp);\\\\n      window.addEventListener('pointercancel', handlePointerUp);\\\\n    }\\\\n\\\\n    return () => {\\\\n      window.removeEventListener('pointermove', handlePointerMove);\\\\n      window.removeEventListener('pointerup', handlePointerUp);\\\\n      window.removeEventListener('pointercancel', handlePointerUp);\\\\n    };\\\\n  }, [draggingIdx, setPoints]);\\\\n\\\\n  // CSS matrix3d expects a comma-separated list of 16 values\\\\n  const matrixString = matrix ? `matrix3d(${matrix.map(n => n.toFixed(6)).join(', ')})` : 'none';\\\\n\\\\n  return (\\\\n    <div className=\\\\\\\"relative w-full h-full\\\\\\\" ref={containerRef}>\\\\n      {/* Target Image Container */}\\\\n      <div \\\\n        className={cn(\\\\n          \\\\\\\"absolute top-0 left-0 border border-cyan-500/30 overflow-hidden shadow-2xl shadow-cyan-900/20 transition-opacity duration-200\\\\\\\",\\\\n          !matrix && \\\\\\\"opacity-20\\\\\\\"\\\\n        )}\\\\n        style={{\\\\n          width: IMAGE_W,\\\\n          height: IMAGE_H,\\\\n          transformOrigin: '0 0',\\\\n          transform: matrixString,\\\\n        }}\\\\n      >\\\\n        <img \\\\n          src=\\\\\\\"https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=800&q=80\\\\\\\" \\\\n          alt=\\\\\\\"Tech background\\\\\\\" \\\\n          className=\\\\\\\"w-full h-full object-cover pointer-events-none select-none\\\\\\\"\\\\n          draggable={false}\\\\n        />\\\\n        {/* Helper grid on image */}\\\\n        <div className=\\\\\\\"absolute inset-0 pointer-events-none bg-[linear-gradient(to_right,#06b6d440_1px,transparent_1px),linear-gradient(to_bottom,#06b6d440_1px,transparent_1px)] bg-[size:20%_20%]\\\\\\\"></div>\\\\n        {/* Corner markers on the image itself */}\\\\n        <div className=\\\\\\\"absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-cyan-400\\\\\\\"></div>\\\\n        <div className=\\\\\\\"absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-cyan-400\\\\\\\"></div>\\\\n        <div className=\\\\\\\"absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-cyan-400\\\\\\\"></div>\\\\n        <div className=\\\\\\\"absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-cyan-400\\\\\\\"></div>\\\\n      </div>\\\\n\\\\n      {/* SVG lines connecting the points to show the quad outline */}\\\\n      <svg className=\\\\\\\"absolute inset-0 w-full h-full pointer-events-none overflow-visible\\\\\\\">\\\\n        <polygon \\\\n          points={points.map(p => `${p.x},${p.y}`).join(' ')} \\\\n          fill={matrix ? \\\\\\\"rgba(6, 182, 212, 0.05)\\\\\\\" : \\\\\\\"rgba(239, 68, 68, 0.1)\\\\\\\"} \\\\n          stroke={matrix ? \\\\\\\"rgba(6, 182, 212, 0.4)\\\\\\\" : \\\\\\\"rgba(239, 68, 68, 0.5)\\\\\\\"} \\\\n          strokeWidth=\\\\\\\"1.5\\\\\\\"\\\\n          strokeDasharray=\\\\\\\"4 4\\\\\\\"\\\\n        />\\\\n        {!matrix && (\\\\n          <text x={points[0].x} y={points[0].y - 20} fill=\\\\\\\"#ef4444\\\\\\\" fontSize=\\\\\\\"12\\\\\\\" className=\\\\\\\"font-mono\\\\\\\">\\\\n            Degenerate / Invalid Quad\\\\n          </text>\\\\n        )}\\\\n      </svg>\\\\n\\\\n      {/* Draggable Handles */}\\\\n      {points.map((p, i) => (\\\\n        <div\\\\n          key={i}\\\\n          className={cn(\\\\n            \\\\\\\"absolute w-8 h-8 -ml-4 -mt-4 rounded-full cursor-grab active:cursor-grabbing flex items-center justify-center group touch-none z-10\\\\\\\",\\\\n            draggingIdx === i ? \\\\\\\"bg-cyan-400/20\\\\\\\" : \\\\\\\"hover:bg-cyan-400/20\\\\\\\"\\\\n          )}\\\\n          style={{ left: p.x, top: p.y }}\\\\n          onPointerDown={(e) => {\\\\n            e.preventDefault();\\\\n            e.currentTarget.setPointerCapture(e.pointerId);\\\\n            setDraggingIdx(i);\\\\n          }}\\\\n        >\\\\n          <div className={cn(\\\\n            \\\\\\\"w-3 h-3 rounded-full border-2 transition-all\\\\\\\",\\\\n            draggingIdx === i \\\\n              ? \\\\\\\"bg-emerald-400 border-emerald-300 scale-150 shadow-[0_0_12px_rgba(52,211,153,0.8)]\\\\\\\" \\\\n              : \\\\\\\"bg-zinc-950 border-cyan-400 group-hover:scale-125 group-hover:border-emerald-400\\\\\\\"\\\\n          )} />\\\\n          {/* Coordinate Label */}\\\\n          <div className=\\\\\\\"absolute top-8 text-[10px] font-mono text-cyan-400 bg-zinc-900/90 border border-zinc-800 px-1.5 py-0.5 rounded pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap shadow-xl\\\\\\\">\\\\n            P{i}: {Math.round(p.x)}, {Math.round(p.y)}\\\\n          </div>\\\\n        </div>\\\\n      ))}\\\\n    </div>\\\\n  );\\\\n}\\\\n\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/components/TransformCanvas.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 1,\\n        \\\"success\\\": true\\n      },\\n      {\\n        \\\"toolName\\\": \\\"workspace_write\\\",\\n        \\\"input\\\": {\\n          \\\"content\\\": \\\"import React, { useEffect, useState } from 'react';\\\\nimport { Card, CardHeader, CardTitle, CardContent } from \\\\\\\"@/components/ui/card\\\\\\\";\\\\nimport { Grid3x3 } from \\\\\\\"lucide-react\\\\\\\";\\\\nimport { cn } from \\\\\\\"@/lib/utils\\\\\\\";\\\\n\\\\ninterface MatrixDisplayProps {\\\\n  matrix: number[] | null;\\\\n}\\\\n\\\\nfunction ValueCell({ value, highlight }: { value: number, highlight?: boolean }) {\\\\n  const [flash, setFlash] = useState(false);\\\\n  const displayValue = value.toFixed(4);\\\\n\\\\n  useEffect(() => {\\\\n    setFlash(true);\\\\n    const timer = setTimeout(() => setFlash(false), 150);\\\\n    return () => clearTimeout(timer);\\\\n  }, [displayValue]);\\\\n\\\\n  return (\\\\n    <div className={cn(\\\\n      \\\\\\\"px-2 py-1.5 rounded bg-zinc-950/50 border border-zinc-800/50 transition-colors duration-300\\\\\\\",\\\\n      flash ? \\\\\\\"bg-cyan-900/40 text-cyan-300 border-cyan-800/50\\\\\\\" : \\\\\\\"text-zinc-300\\\\\\\",\\\\n      highlight && !flash && \\\\\\\"text-emerald-400 font-bold bg-emerald-950/20 border-emerald-900/30\\\\\\\"\\\\n    )}>\\\\n      {displayValue}\\\\n    </div>\\\\n  );\\\\n}\\\\n\\\\nexport default function MatrixDisplay({ matrix }: MatrixDisplayProps) {\\\\n  // Convert CSS column-major matrix to math row-major for display\\\\n  const rowMajor = matrix ? [\\\\n    matrix[0], matrix[4], matrix[8], matrix[12],\\\\n    matrix[1], matrix[5], matrix[9], matrix[13],\\\\n    matrix[2], matrix[6], matrix[10], matrix[14],\\\\n    matrix[3], matrix[7], matrix[11], matrix[15],\\\\n  ] : null;\\\\n\\\\n  return (\\\\n    <Card className=\\\\\\\"bg-zinc-900/60 border-zinc-800 shadow-lg\\\\\\\">\\\\n      <CardHeader className=\\\\\\\"pb-3 border-b border-zinc-800/50\\\\\\\">\\\\n        <CardTitle className=\\\\\\\"text-sm font-medium text-zinc-100 flex items-center gap-2\\\\\\\">\\\\n          <Grid3x3 className=\\\\\\\"w-4 h-4 text-cyan-400\\\\\\\" />\\\\n          变换矩阵 (Transform Matrix)\\\\n        </CardTitle>\\\\n      </CardHeader>\\\\n      <CardContent className=\\\\\\\"pt-4\\\\\\\">\\\\n        {rowMajor ? (\\\\n          <div className=\\\\\\\"space-y-4\\\\\\\">\\\\n            <div className=\\\\\\\"grid grid-cols-4 gap-1.5 font-mono text-[11px] text-right\\\\\\\">\\\\n              {rowMajor.map((val, i) => {\\\\n                // Highlight the perspective components (last row: g, h, 0, 1)\\\\n                const isPerspective = i >= 12 && i <= 14 && val !== 0;\\\\n                return (\\\\n                  <ValueCell key={i} value={val} highlight={isPerspective} />\\\\n                );\\\\n              })}\\\\n            </div>\\\\n            <div className=\\\\\\\"text-[10px] text-zinc-500 leading-relaxed\\\\\\\">\\\\n              <p>1-2行：缩放、旋转与平移 (Affine)</p>\\\\n              <p>第4行：透视分量 (Perspective) <span className=\\\\\\\"text-emerald-400 font-mono\\\\\\\">g, h</span></p>\\\\n            </div>\\\\n          </div>\\\\n        ) : (\\\\n          <div className=\\\\\\\"h-24 flex items-center justify-center text-red-400/80 text-sm font-mono bg-red-950/10 rounded border border-red-900/20\\\\\\\">\\\\n            Invalid Matrix (Det = 0)\\\\n          </div>\\\\n        )}\\\\n      </CardContent>\\\\n    </Card>\\\\n  );\\\\n}\\\\n\\\",\\n          \\\"name\\\": \\\"assets/components/MatrixDisplay.tsx\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/components/MatrixDisplay.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 1,\\n        \\\"success\\\": true\\n      },\\n      {\\n        \\\"toolName\\\": \\\"workspace_write\\\",\\n        \\\"input\\\": {\\n          \\\"name\\\": \\\"assets/components/CoordinateController.tsx\\\",\\n          \\\"content\\\": \\\"import React from 'react';\\\\nimport { Quad } from '@/pages/PerspectiveLabPage';\\\\nimport { Card, CardHeader, CardTitle, CardContent } from \\\\\\\"@/components/ui/card\\\\\\\";\\\\nimport { Slider } from \\\\\\\"@/components/ui/slider\\\\\\\";\\\\nimport { Input } from \\\\\\\"@/components/ui/input\\\\\\\";\\\\nimport { Crosshair } from \\\\\\\"lucide-react\\\\\\\";\\\\n\\\\ninterface CoordinateControllerProps {\\\\n  points: Quad;\\\\n  setPoints: React.Dispatch<React.SetStateAction<Quad>>;\\\\n}\\\\n\\\\nconst POINT_LABELS = ['P0 (左上)', 'P1 (右上)', 'P2 (右下)', 'P3 (左下)'];\\\\n\\\\nexport default function CoordinateController({ points, setPoints }: CoordinateControllerProps) {\\\\n  const handlePointChange = (idx: number, axis: 'x' | 'y', val: number) => {\\\\n    setPoints(prev => {\\\\n      const next = [...prev] as Quad;\\\\n      next[idx] = { ...next[idx], [axis]: val };\\\\n      return next;\\\\n    });\\\\n  };\\\\n\\\\n  return (\\\\n    <Card className=\\\\\\\"bg-zinc-900/60 border-zinc-800 shadow-lg\\\\\\\">\\\\n      <CardHeader className=\\\\\\\"pb-3 border-b border-zinc-800/50\\\\\\\">\\\\n        <CardTitle className=\\\\\\\"text-sm font-medium text-zinc-100 flex items-center gap-2\\\\\\\">\\\\n          <Crosshair className=\\\\\\\"w-4 h-4 text-cyan-400\\\\\\\" />\\\\n          顶点坐标控制 (Vertex Coordinates)\\\\n        </CardTitle>\\\\n      </CardHeader>\\\\n      <CardContent className=\\\\\\\"pt-4 space-y-5\\\\\\\">\\\\n        {points.map((p, i) => (\\\\n          <div key={i} className=\\\\\\\"space-y-3\\\\\\\">\\\\n            <div className=\\\\\\\"flex items-center justify-between\\\\\\\">\\\\n              <span className=\\\\\\\"text-xs font-medium text-zinc-300\\\\\\\">{POINT_LABELS[i]}</span>\\\\n              <span className=\\\\\\\"text-[10px] font-mono text-cyan-500 bg-cyan-950/30 px-1.5 py-0.5 rounded\\\\\\\">\\\\n                {Math.round(p.x)}, {Math.round(p.y)}\\\\n              </span>\\\\n            </div>\\\\n            \\\\n            <div className=\\\\\\\"grid grid-cols-[12px_1fr_40px] gap-3 items-center\\\\\\\">\\\\n              <span className=\\\\\\\"text-[10px] font-mono text-zinc-500\\\\\\\">X</span>\\\\n              <Slider \\\\n                value={[p.x]} \\\\n                min={-200} \\\\n                max={800} \\\\n                step={1}\\\\n                onValueChange={(vals) => handlePointChange(i, 'x', vals[0])}\\\\n                className=\\\\\\\"[&_[role=slider]]:h-3 [&_[role=slider]]:w-3 [&_[role=slider]]:border-cyan-500 [&_[role=slider]]:bg-zinc-950\\\\\\\"\\\\n              />\\\\n              <Input \\\\n                value={Math.round(p.x)}\\\\n                onChange={(e) => handlePointChange(i, 'x', Number(e.target.value) || 0)}\\\\n                className=\\\\\\\"h-6 px-1 text-right text-[10px] font-mono bg-zinc-950 border-zinc-800 focus-visible:ring-cyan-500\\\\\\\"\\\\n              />\\\\n            </div>\\\\n            \\\\n            <div className=\\\\\\\"grid grid-cols-[12px_1fr_40px] gap-3 items-center\\\\\\\">\\\\n              <span className=\\\\\\\"text-[10px] font-mono text-zinc-500\\\\\\\">Y</span>\\\\n              <Slider \\\\n                value={[p.y]} \\\\n                min={-200} \\\\n                max={800} \\\\n                step={1}\\\\n                onValueChange={(vals) => handlePointChange(i, 'y', vals[0])}\\\\n                className=\\\\\\\"[&_[role=slider]]:h-3 [&_[role=slider]]:w-3 [&_[role=slider]]:border-cyan-500 [&_[role=slider]]:bg-zinc-950\\\\\\\"\\\\n              />\\\\n              <Input \\\\n                value={Math.round(p.y)}\\\\n                onChange={(e) => handlePointChange(i, 'y', Number(e.target.value) || 0)}\\\\n                className=\\\\\\\"h-6 px-1 text-right text-[10px] font-mono bg-zinc-950 border-zinc-800 focus-visible:ring-cyan-500\\\\\\\"\\\\n              />\\\\n            </div>\\\\n          </div>\\\\n        ))}\\\\n      </CardContent>\\\\n    </Card>\\\\n  );\\\\n}\\\\n\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/components/CoordinateController.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 1,\\n        \\\"success\\\": true\\n      },\\n      {\\n        \\\"toolName\\\": \\\"workspace_write\\\",\\n        \\\"input\\\": {\\n          \\\"content\\\": \\\"import React from 'react';\\\\nimport { Quad, INITIAL_QUAD } from '@/pages/PerspectiveLabPage';\\\\nimport { Card, CardHeader, CardTitle, CardContent } from \\\\\\\"@/components/ui/card\\\\\\\";\\\\nimport { Button } from \\\\\\\"@/components/ui/button\\\\\\\";\\\\nimport { ScanFace, Square, Move3d, FlipHorizontal } from \\\\\\\"lucide-react\\\\\\\";\\\\n\\\\ninterface ScenarioPresetsProps {\\\\n  setPoints: React.Dispatch<React.SetStateAction<Quad>>;\\\\n}\\\\n\\\\nconst PRESETS = [\\\\n  {\\\\n    name: '标准矩形 (Reset)',\\\\n    desc: '恢复默认无形变状态',\\\\n    icon: Square,\\\\n    points: INITIAL_QUAD\\\\n  },\\\\n  {\\\\n    name: '倾斜文档 (Tilted Scan)',\\\\n    desc: '模拟手机侧面拍摄文档',\\\\n    icon: ScanFace,\\\\n    points: [\\\\n      { x: 160, y: 140 },\\\\n      { x: 440, y: 80 },\\\\n      { x: 490, y: 380 },\\\\n      { x: 90, y: 420 },\\\\n    ] as Quad\\\\n  },\\\\n  {\\\\n    name: '地面视角 (Ground View)',\\\\n    desc: '模拟3D游戏中的地面透视',\\\\n    icon: Move3d,\\\\n    points: [\\\\n      { x: 200, y: 250 },\\\\n      { x: 400, y: 250 },\\\\n      { x: 550, y: 400 },\\\\n      { x: 50, y: 400 },\\\\n    ] as Quad\\\\n  },\\\\n  {\\\\n    name: '仿射错切 (Affine Shear)',\\\\n    desc: '保持平行线的2D仿射变换',\\\\n    icon: FlipHorizontal,\\\\n    points: [\\\\n      { x: 200, y: 100 },\\\\n      { x: 600, y: 100 },\\\\n      { x: 500, y: 400 },\\\\n      { x: 100, y: 400 },\\\\n    ] as Quad\\\\n  }\\\\n];\\\\n\\\\nexport default function ScenarioPresets({ setPoints }: ScenarioPresetsProps) {\\\\n  return (\\\\n    <Card className=\\\\\\\"bg-zinc-900/60 border-zinc-800 shadow-lg\\\\\\\">\\\\n      <CardHeader className=\\\\\\\"pb-3 border-b border-zinc-800/50\\\\\\\">\\\\n        <CardTitle className=\\\\\\\"text-sm font-medium text-zinc-100 flex items-center gap-2\\\\\\\">\\\\n          <ScanFace className=\\\\\\\"w-4 h-4 text-cyan-400\\\\\\\" />\\\\n          典型应用场景 (Scenarios)\\\\n        </CardTitle>\\\\n      </CardHeader>\\\\n      <CardContent className=\\\\\\\"pt-4\\\\\\\">\\\\n        <div className=\\\\\\\"grid grid-cols-1 gap-2\\\\\\\">\\\\n          {PRESETS.map((preset, i) => {\\\\n            const Icon = preset.icon;\\\\n            return (\\\\n              <Button\\\\n                key={i}\\\\n                variant=\\\\\\\"outline\\\\\\\"\\\\n                className=\\\\\\\"w-full justify-start h-auto py-3 px-4 bg-zinc-950/50 border-zinc-800 hover:bg-cyan-950/30 hover:border-cyan-800 hover:text-cyan-400 transition-all text-left\\\\\\\"\\\\n                onClick={() => setPoints(preset.points)}\\\\n              >\\\\n                <Icon className=\\\\\\\"w-4 h-4 mr-3 shrink-0\\\\\\\" />\\\\n                <div className=\\\\\\\"flex flex-col items-start\\\\\\\">\\\\n                  <span className=\\\\\\\"text-xs font-medium\\\\\\\">{preset.name}</span>\\\\n                  <span className=\\\\\\\"text-[10px] text-zinc-500\\\\\\\">{preset.desc}</span>\\\\n                </div>\\\\n              </Button>\\\\n            );\\\\n          })}\\\\n        </div>\\\\n      </CardContent>\\\\n    </Card>\\\\n  );\\\\n}\\\\n\\\",\\n          \\\"name\\\": \\\"assets/components/ScenarioPresets.tsx\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/components/ScenarioPresets.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 0,\\n        \\\"success\\\": true\\n      },\\n      {\\n        \\\"toolName\\\": \\\"workspace_write\\\",\\n        \\\"input\\\": {\\n          \\\"name\\\": \\\"assets/components/TheoryAccordion.tsx\\\",\\n          \\\"content\\\": \\\"import React from 'react';\\\\nimport {\\\\n  Accordion,\\\\n  AccordionContent,\\\\n  AccordionItem,\\\\n  AccordionTrigger,\\\\n} from \\\\\\\"@/components/ui/accordion\\\\\\\";\\\\nimport 'katex/dist/katex.min.css';\\\\nimport { InlineMath, BlockMath } from 'react-katex';\\\\nimport { Card, CardHeader, CardTitle, CardContent } from \\\\\\\"@/components/ui/card\\\\\\\";\\\\nimport { BookOpen } from \\\\\\\"lucide-react\\\\\\\";\\\\n\\\\nexport default function TheoryAccordion() {\\\\n  return (\\\\n    <Card className=\\\\\\\"bg-zinc-900/60 border-zinc-800 shadow-lg\\\\\\\">\\\\n      <CardHeader className=\\\\\\\"pb-3 border-b border-zinc-800/50\\\\\\\">\\\\n        <CardTitle className=\\\\\\\"text-sm font-medium text-zinc-100 flex items-center gap-2\\\\\\\">\\\\n          <BookOpen className=\\\\\\\"w-4 h-4 text-cyan-400\\\\\\\" />\\\\n          理论解析 (Theory)\\\\n        </CardTitle>\\\\n      </CardHeader>\\\\n      <CardContent className=\\\\\\\"pt-2 px-4\\\\\\\">\\\\n        <Accordion type=\\\\\\\"single\\\\\\\" collapsible className=\\\\\\\"w-full\\\\\\\" defaultValue=\\\\\\\"item-1\\\\\\\">\\\\n          <AccordionItem value=\\\\\\\"item-1\\\\\\\" className=\\\\\\\"border-zinc-800/50\\\\\\\">\\\\n            <AccordionTrigger className=\\\\\\\"text-xs font-medium text-zinc-300 hover:text-cyan-400\\\\\\\">\\\\n              什么是透视变换？\\\\n            </AccordionTrigger>\\\\n            <AccordionContent className=\\\\\\\"text-xs text-zinc-400 leading-relaxed space-y-3\\\\\\\">\\\\n              <p>\\\\n                透视变换（Perspective Transformation）是将图像投影到一个新的视平面，也称为投影映射。它可以将一个矩形映射为任意凸四边形。\\\\n              </p>\\\\n              <p>\\\\n                在 2D 平面中，透视变换通过一个 3x3 的矩阵（具有 8 个自由度）来实现，其坐标映射公式为：\\\\n              </p>\\\\n              <div className=\\\\\\\"bg-zinc-950/50 p-2 rounded border border-zinc-800 overflow-x-auto text-cyan-300\\\\\\\">\\\\n                <BlockMath math=\\\\\\\"x' = \\\\\\\\frac{ax + by + c}{gx + hy + 1}\\\\\\\" />\\\\n                <BlockMath math=\\\\\\\"y' = \\\\\\\\frac{dx + ey + f}{gx + hy + 1}\\\\\\\" />\\\\n              </div>\\\\n              <p>\\\\n                其中分母 <InlineMath math=\\\\\\\"gx + hy + 1\\\\\\\" /> 是透视分量，它使得不同位置的点缩放比例不同，从而产生“近大远小”的视觉效果。\\\\n              </p>\\\\n            </AccordionContent>\\\\n          </AccordionItem>\\\\n\\\\n          <AccordionItem value=\\\\\\\"item-2\\\\\\\" className=\\\\\\\"border-zinc-800/50\\\\\\\">\\\\n            <AccordionTrigger className=\\\\\\\"text-xs font-medium text-zinc-300 hover:text-cyan-400\\\\\\\">\\\\n              与仿射变换的区别\\\\n            </AccordionTrigger>\\\\n            <AccordionContent className=\\\\\\\"text-xs text-zinc-400 leading-relaxed space-y-3\\\\\\\">\\\\n              <p>\\\\n                <strong>仿射变换 (Affine)</strong> 是透视变换的特例。当透视分量 <InlineMath math=\\\\\\\"g = 0\\\\\\\" /> 且 <InlineMath math=\\\\\\\"h = 0\\\\\\\" /> 时，分母恒为 1，变换退化为仿射变换。\\\\n              </p>\\\\n              <ul className=\\\\\\\"list-disc pl-4 space-y-1 text-zinc-500\\\\\\\">\\\\n                <li>\\\\n                  <span className=\\\\\\\"text-zinc-300\\\\\\\">仿射变换：</span> 保持直线的平行性（如平行四边形变换后仍是平行四边形），只有 6 个自由度。\\\\n                </li>\\\\n                <li>\\\\n                  <span className=\\\\\\\"text-zinc-300\\\\\\\">透视变换：</span> 不保证平行线依然平行，直线变换后仍是直线，有 8 个自由度。\\\\n                </li>\\\\n              </ul>\\\\n            </AccordionContent>\\\\n          </AccordionItem>\\\\n\\\\n          <AccordionItem value=\\\\\\\"item-3\\\\\\\" className=\\\\\\\"border-zinc-800/50 border-b-0\\\\\\\">\\\\n            <AccordionTrigger className=\\\\\\\"text-xs font-medium text-zinc-300 hover:text-cyan-400\\\\\\\">\\\\n              实际应用场景\\\\n            </AccordionTrigger>\\\\n            <AccordionContent className=\\\\\\\"text-xs text-zinc-400 leading-relaxed space-y-2\\\\\\\">\\\\n              <ul className=\\\\\\\"list-disc pl-4 space-y-2\\\\\\\">\\\\n                <li>\\\\n                  <span className=\\\\\\\"text-cyan-400\\\\\\\">文档扫描校正：</span> \\\\n                  通过检测倾斜文档的四个角，计算透视矩阵（单应性矩阵），将其逆向映射回标准矩形。\\\\n                </li>\\\\n                <li>\\\\n                  <span className=\\\\\\\"text-cyan-400\\\\\\\">图像全景拼接：</span> \\\\n                  将不同角度拍摄的照片，通过特征点匹配计算透视矩阵，投影到同一个平面上。\\\\n                </li>\\\\n                <li>\\\\n                  <span className=\\\\\\\"text-cyan-400\\\\\\\">UI / 3D 渲染：</span> \\\\n                  CSS3 的 <code className=\\\\\\\"text-emerald-400 bg-emerald-400/10 px-1 rounded\\\\\\\">matrix3d</code> 底层即使用 4x4 矩阵实现 3D 空间中的透视投影。\\\\n                </li>\\\\n              </ul>\\\\n            </AccordionContent>\\\\n          </AccordionItem>\\\\n        </Accordion>\\\\n      </CardContent>\\\\n    </Card>\\\\n  );\\\\n}\\\\n\\\"\\n        },\\n        \\\"output\\\": \\\"{\\\\\\\"success\\\\\\\":true,\\\\\\\"path\\\\\\\":\\\\\\\"assets/components/TheoryAccordion.tsx\\\\\\\",\\\\\\\"sessionId\\\\\\\":\\\\\\\"8de0d9c4-c170-484d-aec0-f7fc0d8308ab\\\\\\\"}\\\",\\n        \\\"duration\\\": 1,\\n        \\\"success\\\": true\\n      }\\n    ],\\n    \\\"subAgentResults\\\": []\\n  }\\n}\"}"}},"error":null,"elapsed_time":0.001}}

