\\\"purpose\\\": \\\"展示3D虚拟汽车、4个广角摄像头布局及190度视场角\\\",\\n      \\\"ui_approach\\\": [\\n        \\\"Three.js / @react-three/fiber 渲染车辆和视锥\\\",\\n        \\\"shadcn Switch 切换摄像头开关\\\",\\n        \\\"Framer Motion 视角平滑过渡\\\"\\n      ],\\n      \\\"data_points\\\": [\\n        \\\"前/后/左/右摄像头状态\\\",\\n        \\\"视场角参数 (190°)\\\"\\n      ]\\n    },\\n    {\\n      \\\"file_name\\\": \\\"PrincipleStepper.tsx\\\",\\n      \\\"purpose\\\": \\\"核心原理分步演示的导航容器，控制4大步骤的流转\\\",\\n      \\\"ui_approach\\\": [\\n        \\\"shadcn Progress 进度条\\\",\\n        \\\"shadcn Button 步骤切换\\\",\\n        \\\"Framer Motion 页面滑动切换\\\"\\n      ],\\n      \\\"data_points\\\": [\\n        \\\"当前步骤索引\\\",\\n        \\\"步骤说明文本\\\"\\n      ]\\n    },\\n    {\\n      \\\"file_name\\\": \\\"DistortionLab.tsx\\\",\\n      \\\"purpose\\\": \\\"演示鱼眼原图与桶形畸变校正过程\\\",\\n      \\\"ui_approach\\\": [\\n        \\\"CSS Transform 模拟图像畸变\\\",\\n        \\\"shadcn Slider 控制校正强度\\\",\\n        \\\"Framer Motion 图像形变动画\\\"\\n      ],\\n      \\\"data_points\\\": [\\n        \\\"畸变系数 (k1, k2)\\\",\\n        \\\"校正比例 (0-100%)\\\"\\n      ]\\n    },\\n    {\\n      \\\"file_name\\\": \\\"PerspectiveLab.tsx\\\",\\n      \\\"purpose\\\": \\\"演示透视变换（侧视投影为鸟瞰图）\\\",\\n      \\\"ui_approach\\\": [\\n        \\\"Framer Motion 3D 旋转动画 (rotateX)\\\",\\n        \\\"shadcn Switch 切换透视/正交视角\\\"\\n      ],\\n      \\\"data_points\\\": [\\n        \\\"俯仰角度\\\",\\n        \\\"投影矩阵参数示意\\\"\\n      ]\\n    },\\n    {\\n      \\\"file_name\\\": \\\"StitchingLab.tsx\\\",\\n      \\\"purpose\\\": \\\"演示4图合成拼接及3D车模叠加\\\",\\n      \\\"ui_approach\\\": [\\n        \\\"Tailwind Grid 布局4张鸟瞰图\\\",\\n        \\\"shadcn Slider 控制边缘融合渐变\\\",\\n        \\\"shadcn Switch 切换中心3D车模叠加\\\"\\n      ],\\n      \\\"data_points\\\": [\\n        \\\"融合宽度 (px)\\\",\\n        \\\"车模透明度\\\"\\n      ]\\n    },\\n    {\\n      \\\"file_name\\\": \\\"CalibrationWorkbench.tsx\\\",\\n      \\\"purpose\\\": \\\"交互实操小练习，提供参数滑块让学生手动修复拼接瑕疵\\\",\\n      \\\"ui_approach\\\": [\\n        \\\"shadcn Slider 控制X/Y平移和曝光/色彩补偿\\\",\\n        \\\"react-resizable-panels 复杂控制台布局\\\",\\n        \\\"实时画布更新反馈\\\"\\n      ],\\n      \\\"data_points\\\": [\\n        \\\"前摄 X/Y 偏移\\\",\\n        \\\"后摄曝光度\\\",\\n        \\\"左右摄色彩偏差\\\"\\n      ]\\n    }\\n  ],\\n  \\\"coverage_matrix\\\": [\\n    {\\n      \\\"moduleTitle\\\": \\\"硬件认知模块\\\",\\n      \\\"componentFiles\\\": [\\n        \\\"HardwareView.tsx\\\",\\n        \\\"AvmNavigation.tsx\\\"\\n      ]\\n    },\\n    {\\n      \\\"moduleTitle\\\": \\\"核心原理分步演示模块\\\",\\n      \\\"componentFiles\\\": [\\n        \\\"PrincipleStepper.tsx\\\",\\n        \\\"DistortionLab.tsx\\\",\\n        \\\"PerspectiveLab.tsx\\\",\\n        \\\"StitchingLab.tsx\\\"\\n      ]\\n    },\\n    {\\n      \\\"moduleTitle\\\": \\\"交互实操模块\\\",\\n      \\\"componentFiles\\\": [\\n        \\\"CalibrationWorkbench.tsx\\\"\\n      ]\\n    }\\n  ],\\n  \\\"teaching_guide\\\": {\\n    \\\"overview\\\": \\\"本教程采用“探索-理解-实践”的教学闭环。先通过3D视角建立硬件空间感，再通过分步参数调节理解抽象的图像算法，最后在虚拟工作台中检验学习成果。\\\",\\n    \\\"objectives\\\": [\\n      \\\"掌握AVM系统的4摄像头布局及超广角覆盖原理\\\",\\n      \\\"直观理解畸变校正、透视变换和图像拼接的视觉效果及作用\\\",\\n      \\\"能够发现全景拼接中的错位与色差，并理解其调试方向\\\"\\n    ],\\n    \\\"duration\\\": \\\"45分钟\\\",\\n    \\\"componentGuides\\\": [\\n      {\\n        \\\"component\\\": \\\"HardwareView.tsx\\\",\\n        \\\"duration\\\": \\\"10分钟\\\",\\n        \\\"tip\\\": \\\"引导学生逐个开启摄像头，观察视场角（FOV）覆盖范围，重点讲解相邻摄像头视角的重叠区（这是后续拼接的基础）。\\\"\\n      },\\n      {\\n        \\\"component\\\": \\\"DistortionLab.tsx & PerspectiveLab.tsx\\\",\\n        \\\"duration\\\": \\\"15分钟\\\",\\n        \\\"tip\\\": \\\"让学生反复拖动滑块，观察直线在畸变校正前后的弯曲变化；在透视变换中，强调视角从“平视”到“上帝视角”的转换逻辑。\\\"\\n      },\\n      {\\n        \\\"component\\\": \\\"StitchingLab.tsx\\\",\\n        \\\"duration\\\": \\\"10分钟\\\",\\n        \\\"tip\\\": \\\"重点演示“融合渐变”滑块，让学生看到硬拼接边界（明显的分割线）如何通过算法变得平滑自然。\\\"\\n      },\\n      {\\n        \\\"component\\\": \\\"CalibrationWorkbench.tsx\\\",\\n        \\\"duration\\\": \\\"10分钟\\\",\\n        \\\"tip\\\": \\\"设置一个典型的错位场景，鼓励学生先通过平移（X/Y）对齐标线，再通过色彩滑块消除画面色差，完成最终的全景图调校。\\\"\\n      }\\n    ]\\n  }\\n}\"}"}},"error":null,"elapsed_time":0.002}}

