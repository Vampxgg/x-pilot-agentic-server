sName=\\\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:40px_40px]\\\" />\\n          \\n          {/* Car Placeholder */}\\n          <div className=\\\"absolute inset-0 flex items-center justify-center\\\">\\n            <div className=\\\"w-24 h-48 bg-zinc-800/80 border border-zinc-600 rounded-md flex items-center justify-center\\\">\\n              <span className=\\\"text-zinc-500 text-xs font-mono\\\">CAR</span>\\n            </div>\\n          </div>\\n\\n          {/* Simulated projected texture */}\\n          <div className=\\\"absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-cyan-500/20 to-transparent\\\" />\\n        </motion.div>\\n\\n        {/* Projection Rays (visible only when transforming) */}\\n        <div className=\\\"absolute inset-0 pointer-events-none flex items-center justify-center opacity-20\\\">\\n           {isBirdEye && (\\n             <svg className=\\\"w-full h-full absolute\\\" viewBox=\\\"0 0 100 100\\\" preserveAspectRatio=\\\"none\\\">\\n               <line x1=\\\"50\\\" y1=\\\"0\\\" x2=\\\"20\\\" y2=\\\"80\\\" stroke=\\\"#06b6d4\\\" strokeWidth=\\\"0.2\\\" strokeDasharray=\\\"1 1\\\" />\\n               <line x1=\\\"50\\\" y1=\\\"0\\\" x2=\\\"80\\\" y2=\\\"80\\\" stroke=\\\"#06b6d4\\\" strokeWidth=\\\"0.2\\\" strokeDasharray=\\\"1 1\\\" />\\n             </svg>\\n           )}\\n        </div>\\n\\n        <div className=\\\"absolute bottom-6 left-6 flex gap-3\\\">\\n          <Badge variant=\\\"outline\\\" className=\\\"bg-zinc-900/80 border-zinc-700 text-zinc-300 font-mono transition-all\\\">\\n            Pitch: {rotateX}°\\n          </Badge>\\n          <Badge variant=\\\"outline\\\" className=\\\"bg-zinc-900/80 border-zinc-700 text-zinc-300 font-mono\\\">\\n            Matrix: {isBirdEye ? \\\"IPM (Inverse Perspective)\\\" : \\\"Identity\\\"}\\n          </Badge>\\n        </div>\\n      </div>\\n\\n      {/* Control Panel */}\\n      <div className=\\\"w-80 border-l border-zinc-800 bg-zinc-950/50 p-6 flex flex-col gap-8\\\">\\n        <div>\\n          <h3 className=\\\"text-lg font-semibold text-zinc-100 flex items-center gap-2 mb-1\\\">\\n            <Layers className=\\\"w-5 h-5 text-cyan-500\\\" />\\n            投影控制\\n          </h3>\\n          <p className=\\\"text-xs text-zinc-500\\\">切换视角投影矩阵</p>\\n        </div>\\n\\n        <div className=\\\"space-y-6\\\">\\n          <div className=\\\"space-y-4 bg-zinc-900/40 p-4 rounded-xl border border-zinc-800/50\\\">\\n            <div className=\\\"flex items-center justify-between\\\">\\n              <Label htmlFor=\\\"bird-eye-mode\\\" className=\\\"text-zinc-300 cursor-pointer\\\">\\n                启用鸟瞰投影 (IPM)\\n              </Label>\\n              <Switch \\n                id=\\\"bird-eye-mode\\\" \\n                checked={isBirdEye} \\n                onCheckedChange={setIsBirdEye}\\n                className=\\\"data-[state=checked]:bg-cyan-500\\\"\\n              />\\n            </div>\\n          </div>\\n\\n          <div className=\\\"bg-cyan-950/20 border border-cyan-900/50 rounded-xl p-4\\\">\\n            <h4 className=\\\"text-sm font-medium text-cyan-400 mb-2\\\">教学提示</h4>\\n            <p className=\\\"text-xs text-cyan-100/70 leading-relaxed\\\">\\n              透视变换（IPM）通过计算相机与地面的几何关系，将原本包含透视缩变的图像，重新投影到平行的地面坐标系上，从而实现“上帝视角”。\\n            </p>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  );\\n}\\n\"}"}},"error":null,"elapsed_time":0.002}}

