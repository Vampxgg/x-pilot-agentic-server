# LLM Provider API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
ZHIPU_API_KEY=your-zhipu-key

# Google Vertex AI (official GCP service)
# 1) Create a GCP service account and grant the "Vertex AI User" role
# 2) Download the JSON key and place it under secrets/ or another path
# 3) On Windows, prefer forward slashes or an absolute path to avoid backslash escaping
GOOGLE_APPLICATION_CREDENTIALS=./secrets/vertex-sa.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Public base URL for generated file downloads (e.g. http://your-domain:3000)
# Used to build full download URLs returned to frontend
PUBLIC_BASE_URL=http://192.168.31.45:3000

# Web Search (Tavily — https://app.tavily.com)
TAVILY_API_KEY=tvly-your-tavily-key
# Fallback provider (SearchApi.io — https://www.searchapi.io)
SEARCH_API_KEY=your-searchapi-key

# Memory Store (file | postgres)
MEMORY_STORE=file

# PostgreSQL — matches docker-compose.yml (docker compose up -d)
DATABASE_URL=postgresql://user:password@localhost:5432/xpilot

# Checkpoint Store for LangGraph (memory | postgres)
CHECKPOINT_STORE=postgres
# Optional; if unset, DATABASE_URL is used
CHECKPOINT_POSTGRES_URL=postgresql://user:password@localhost:5432/xpilot
CHECKPOINT_MAX_MESSAGES=100

# Logging
LOG_LEVEL=info

# SSE / 流式连接保持时间（毫秒，默认 10 分钟）
SSE_KEEPALIVE_TIMEOUT_MS=600000

# 代理
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# 知识库
DIFY_API_BASE_URL=http://localhost:port/v1
DIFY_DATASET_API_KEY=your-dify-dataset-api-key
KNOWLEDGE_ALLOW_UNSCOPED_SEARCH=false
KNOWLEDGE_MAX_DATASETS=20
KNOWLEDGE_RETRIEVE_CONCURRENCY=6
KNOWLEDGE_DEFAULT_SEARCH_METHOD=hybrid_search
KNOWLEDGE_DEFAULT_TOP_K=10
KNOWLEDGE_DIFY_TOP_K_MAX=50
KNOWLEDGE_SCORE_THRESHOLD=0
KNOWLEDGE_MAX_TOKENS=8000
KNOWLEDGE_TIMEOUT=45000
KNOWLEDGE_FALLBACK_SEARCH_METHOD=keyword_search
RERANK_ENABLED=true
RERANK_PROVIDER=siliconflow
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_URL=https://api.siliconflow.cn/v1/rerank
RERANK_TIMEOUT=30000
SILICONFLOW_API_KEY=your-siliconflow-rerank-key